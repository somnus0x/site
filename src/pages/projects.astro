---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: '[redacted]',
    description: 'twitter-first crypto betting platform. shipping soon.',
    year: '2025',
    status: 'active',
    stack: ['nestjs', 'react', 'solidity', 'firebase'],
  },
  {
    title: 'kanly',
    description: 'formal vendetta protocols for honest intellectual conflict.',
    year: '2026',
    status: 'active',
    link: '/kanly',
    stack: ['markdown', 'claude code'],
  },
  {
    title: 'tokenomist.ai',
    description: 'tokenomics analysis platform. clients: coinbase, falconx.',
    year: '2023',
    status: 'shipped',
    stack: ['python', 'react', 'postgresql'],
  },
  {
    title: 'knowhere labs',
    description: "terra's first nft marketplace. $30m trading volume.",
    year: '2021',
    status: 'archived',
    stack: ['react', 'rust', 'cosmwasm', 'terra'],
  },
];

type Status = 'active' | 'shipped' | 'archived';

const grouped: Record<Status, typeof projects> = { active: [], shipped: [], archived: [] };
projects.forEach(p => grouped[p.status as Status].push(p));
const buckets: Status[] = ['active', 'shipped', 'archived'];
---

<Layout title="projects" description="Things I've built" wide>
  <header class="animate-fade-up" style="margin-bottom: 48px;">
    <h1 style="font-size: 2.5rem; letter-spacing: -0.025em;">projects</h1>
    <p class="text-dim" style="margin-top: 12px; font-size: 17px;">Grouped by what's still moving.</p>
  </header>

  {buckets.map((bucket, idx) => (
    grouped[bucket].length > 0 && (
      <section
        class={`animate-fade-up delay-${idx + 1} mb-10`}
      >
        <!-- Margin-metadata layout at lg+, single column below -->
        <div class="block lg:grid" style="gap: 32px;" data-margin-grid>
          <!-- Status label (margin meta) -->
          <aside class="ps-margin-meta hidden lg:block" style={`text-align: right; color: ${bucket === 'active' ? 'var(--color-accent)' : 'var(--color-faint)'};`}>
            <div style={`text-transform: uppercase; color: ${bucket === 'active' ? 'var(--color-accent)' : 'var(--color-faint)'};`}>
              {bucket}
            </div>
            <div class="text-dim font-mono">
              {grouped[bucket].length} {grouped[bucket].length === 1 ? 'project' : 'projects'}
            </div>
          </aside>

          <!-- Mobile-only bucket label -->
          <div class="lg:hidden font-mono text-[11px] tracking-[0.1em] uppercase mb-4" style={`color: ${bucket === 'active' ? 'var(--color-accent)' : 'var(--color-faint)'};`}>
            {bucket} &middot; {grouped[bucket].length}
          </div>

          <!-- Cards -->
          <div style="display: flex; flex-direction: column; gap: 14px;">
            {grouped[bucket].map((project) => (
              <div class="ps-card ps-card-clickable" style="position: relative; cursor: pointer;">
                {/* Active dot */}
                {project.status === 'active' && (
                  <span style="position: absolute; top: 22px; left: -4px; width: 6px; height: 6px; border-radius: 999px; background: var(--color-accent); box-shadow: 0 0 0 4px color-mix(in oklch, var(--color-accent) 18%, transparent);" />
                )}

                {/* Title + year */}
                <div style="display: grid; grid-template-columns: 1fr auto; gap: 24px; align-items: baseline; margin-bottom: 12px;">
                  <h3 style="font-size: 1.4rem;">
                    {project.link ? (
                      <a href={project.link} class="hover:text-accent transition-colors no-underline" style="color: var(--color-text);">{project.title}</a>
                    ) : (
                      project.title
                    )}
                  </h3>
                  <span class="font-mono text-faint" style="font-size: 12px; letter-spacing: 0.08em;">{project.year}</span>
                </div>

                {/* Description */}
                <p class="text-dim" style="font-size: 16px; line-height: 1.65; margin-bottom: 18px;">{project.description}</p>

                {/* Stack + status */}
                <div style="display: flex; flex-wrap: wrap; gap: 6px; align-items: center; justify-content: space-between;">
                  <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                    {project.stack.map((tech) => (
                      <span class="ps-tag">{tech}</span>
                    ))}
                  </div>
                  <span class="font-mono" style={`font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: ${project.status === 'active' ? 'var(--color-accent)' : 'var(--color-faint)'};`}>
                    {project.status}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  ))}
</Layout>

<style>
  [data-margin-grid] {
    grid-template-columns: 140px minmax(0, 1fr);
  }
</style>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="projects" description="Things I've built" wide>
  <div class="space-y-8">
    <h1 class="font-display text-4xl font-normal animate-fade-up">projects</h1>

    <div class="space-y-6 mt-10">
      <div class="border border-border rounded-xl bg-surface p-7 animate-fade-up delay-1">
        <h2 class="font-display text-xl mb-3">[redacted]</h2>
        <p class="text-dim mb-4">twitter-first crypto betting platform. shipping soon.</p>
        <div class="text-faint font-mono text-xs uppercase tracking-wider">
          <span class="text-text">stack:</span> nestjs, react, solidity, firebase
        </div>
      </div>

      <div class="border border-border rounded-xl bg-surface p-7 animate-fade-up delay-2">
        <h2 class="font-display text-xl mb-3">knowhere labs</h2>
        <p class="text-dim mb-4">terra's first nft marketplace. $30m trading volume. acquired 2022.</p>
        <div class="text-faint font-mono text-xs uppercase tracking-wider">
          <span class="text-text">role:</span> co-founder, full-stack
        </div>
      </div>

      <div class="border border-border rounded-xl bg-surface p-7 animate-fade-up delay-3">
        <h2 class="font-display text-xl mb-3">tokenomist.ai</h2>
        <p class="text-dim mb-4">tokenomics analysis platform. clients: coinbase, falconx.</p>
        <div class="text-faint font-mono text-xs uppercase tracking-wider">
          <span class="text-text">role:</span> tech lead
        </div>
      </div>

      <div class="border border-border rounded-xl bg-surface p-7 animate-fade-up delay-4">
        <h2 class="font-display text-xl mb-3">kanly</h2>
        <p class="text-dim mb-4">formal vendetta protocols for honest intellectual conflict.</p>
        <div class="text-sm">
          <a href="/kanly" class="text-spice hover:underline">→ view protocols</a>
        </div>
      </div>
    </div>
  </div>
</Layout>

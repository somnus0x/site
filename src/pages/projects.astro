---
import Layout from '../layouts/Layout.astro';
---

<Layout title="projects" description="Things I've built">
  <div class="space-y-8">
    <h1 class="text-4xl font-bold">projects</h1>

    <div class="space-y-8 mt-8">
      <div class="border border-surface p-6">
        <h2 class="text-2xl font-bold mb-3">[redacted]</h2>
        <p class="text-muted mb-4">twitter-first crypto betting platform. shipping soon.</p>
        <div class="text-sm text-muted">
          <span class="text-text">stack:</span> nestjs, react, solidity, firebase
        </div>
      </div>

      <div class="border border-surface p-6">
        <h2 class="text-2xl font-bold mb-3">knowhere labs</h2>
        <p class="text-muted mb-4">terra's first nft marketplace. $30m trading volume. acquired 2022.</p>
        <div class="text-sm text-muted">
          <span class="text-text">role:</span> co-founder, full-stack
        </div>
      </div>

      <div class="border border-surface p-6">
        <h2 class="text-2xl font-bold mb-3">tokenomist.ai</h2>
        <p class="text-muted mb-4">tokenomics analysis platform. clients: coinbase, falconx.</p>
        <div class="text-sm text-muted">
          <span class="text-text">role:</span> tech lead
        </div>
      </div>

      <div class="border border-surface p-6">
        <h2 class="text-2xl font-bold mb-3">kanly</h2>
        <p class="text-muted mb-4">formal vendetta protocols for honest intellectual conflict.</p>
        <div class="text-sm">
          <a href="/kanly" class="text-accent hover:underline">→ view protocols</a>
        </div>
      </div>
    </div>
  </div>
</Layout>

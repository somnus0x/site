---
import Layout from '../../layouts/Layout.astro';

const technical = [
  {
    title: "Clean Code",
    author: "Robert C. Martin",
    cover: "https://covers.openlibrary.org/b/isbn/9780132350884-M.jpg",
    desc: "the handbook everyone references and half actually read. naming, functions, error handling. the basics that separate readable code from clever code."
  },
  {
    title: "Clean Architecture",
    author: "Robert C. Martin",
    cover: "https://covers.openlibrary.org/b/isbn/9780134494166-M.jpg",
    desc: "boundaries, dependency rules, the separation that lets you swap frameworks without rewriting everything. read this before your first major refactor."
  },
  {
    title: "The Pragmatic Programmer",
    author: "Hunt & Thomas",
    cover: "https://covers.openlibrary.org/b/isbn/9780135957059-M.jpg",
    desc: "the meta-book. not about any language or framework. about how to think like a programmer. DRY, orthogonality, tracer bullets."
  },
  {
    title: "Design Patterns",
    author: "Gang of Four",
    cover: "https://covers.openlibrary.org/b/isbn/9780201633610-M.jpg",
    desc: "don't read this cover to cover. watch the <a href='https://www.youtube.com/watch?v=v9ejT8FO-7I&list=PLrhzvIcii6GNjpARdnO4ueTUAVR9eMBpc' target='_blank' rel='noopener' class='text-spice hover:underline'>playlist</a> instead. implement the ones you need, learn the rest when you hit them in the wild.",
    link: "https://www.youtube.com/watch?v=v9ejT8FO-7I&list=PLrhzvIcii6GNjpARdnO4ueTUAVR9eMBpc"
  },
  {
    title: "Domain-Driven Design Distilled",
    author: "Vaughn Vernon",
    cover: "https://covers.openlibrary.org/b/isbn/9780134434421-M.jpg",
    desc: "the compressed version. bounded contexts, aggregates, ubiquitous language. the thinking tool for systems that are bigger than one person's head."
  },
  {
    title: "Cracking the Coding Interview",
    author: "Gayle Laakmann McDowell",
    cover: "https://covers.openlibrary.org/b/isbn/9780984782857-M.jpg",
    desc: "189 programming questions and solutions. the standard prep book. don't memorize — understand the patterns behind the problems."
  },
];

const nonTechnical = [
  {
    title: "The Mythical Man-Month",
    author: "Fred Brooks",
    cover: "https://covers.openlibrary.org/b/isbn/9780201835953-M.jpg",
    desc: "written in 1975, still true. adding people to a late project makes it later. the communication overhead chapter alone is worth it."
  },
  {
    title: "The Clean Coder",
    author: "Robert C. Martin",
    cover: "https://covers.openlibrary.org/b/isbn/9780137081073-M.jpg",
    desc: "not about code. about professionalism. saying no, estimating honestly, handling pressure. the book about being a developer, not writing code."
  },
  {
    title: "Don't Make Me Think",
    author: "Steve Krug",
    cover: "https://covers.openlibrary.org/b/isbn/9780321965516-M.jpg",
    desc: "UX for people who don't do UX. every programmer should read this. your users aren't reading your interface — they're scanning it."
  },
];
---

<Layout title="books for programmers" description="A reading list I compiled for junior devs. Technical foundations and the non-technical stuff nobody teaches you.">
  <div class="space-y-8">
    <h1 class="font-display text-4xl font-normal animate-fade-up">books for programmers</h1>
    <p class="text-dim animate-fade-up delay-1">compiled this for junior devs I've worked with. the technical books build your foundation. the non-technical ones build everything else.</p>

    <div class="animate-fade-up delay-2 mt-12">
      <h2 class="font-mono text-sm text-spice mb-6">technical (IC track)</h2>
      <p class="text-faint text-sm mb-8">heavily focused on backend since frontend patterns are locked by framework.</p>

      <div class="space-y-8">
        {technical.map((book) => (
          <div class="flex gap-5 items-start">
            <img
              src={book.cover}
              alt={book.title}
              class="w-16 h-auto rounded shadow-md flex-shrink-0 bg-surface"
              loading="lazy"
            />
            <div>
              <h3 class="font-display text-lg text-text">{book.title}</h3>
              <p class="text-faint text-xs font-mono mb-1">{book.author}</p>
              <p class="text-dim text-sm" set:html={book.desc} />
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="animate-fade-up delay-3 mt-16">
      <h2 class="font-mono text-sm text-gold mb-6">non-technical</h2>
      <p class="text-faint text-sm mb-8">for communicating thought. useful during work and interviews.</p>

      <div class="space-y-8">
        {nonTechnical.map((book) => (
          <div class="flex gap-5 items-start">
            <img
              src={book.cover}
              alt={book.title}
              class="w-16 h-auto rounded shadow-md flex-shrink-0 bg-surface"
              loading="lazy"
            />
            <div>
              <h3 class="font-display text-lg text-text">{book.title}</h3>
              <p class="text-faint text-xs font-mono mb-1">{book.author}</p>
              <p class="text-dim text-sm" set:html={book.desc} />
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="animate-fade-up delay-4 mt-16">
      <h2 class="font-mono text-sm text-water mb-6">extra</h2>
      <div class="space-y-3">
        <p class="text-dim text-sm"><a href="https://www.programmingbooks.dev/" target="_blank" rel="noopener" class="text-spice hover:underline">programmingbooks.dev</a> — crowdsourced list if you want to go deeper.</p>
        <p class="text-dim text-sm"><a href="https://www.youtube.com/watch?v=pywzWVeGVfo&list=WL&index=175" target="_blank" rel="noopener" class="text-spice hover:underline">system design primer</a> — video playlist for interview prep and architectural thinking.</p>
      </div>
    </div>
  </div>
</Layout>

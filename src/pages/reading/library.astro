---

<Layout title="library" description="A curated reading list built over 200+ books across strategy, systems thinking, technical leadership, philosophy, and fiction.">
  <div class="space-y-8">
    <h1 class="font-display text-4xl font-normal animate-fade-up">library</h1>
    <p class="text-dim animate-fade-up delay-1">a curated reading list built over 200+ books across strategy, systems thinking, technical leadership, philosophy, and fiction.</p>

    {sections.map((section, i) => (
      <div class={`animate-fade-up delay-${i + 2} mt-16`}>
        <h2 class={`font-mono text-sm ${section.color} mb-6`}>{section.title}</h2>

        <div class="space-y-8">
          {section.data.map((book) => (
            <div class="flex gap-5 items-start">
              {book.cover ? (
                <img
                  src={book.cover}
                  alt={book.title}
                  class="w-16 h-auto rounded shadow-md flex-shrink-0 bg-surface"
                  loading="lazy"
                />
              ) : (
                <div class="w-16 h-24 rounded shadow-md flex-shrink-0 bg-surface border border-border flex items-center justify-center">
                  <span class="text-faint text-xs font-mono text-center px-1">{book.title.split(' ').slice(0, 2).join(' ')}</span>
                </div>
              )}
              <div>
                <h3 class="font-display text-lg text-text">{book.title}</h3>
                <p class="text-faint text-xs font-mono mb-1">{book.author}</p>
                <p class="text-dim text-sm" set:html={book.desc} />
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</Layout>

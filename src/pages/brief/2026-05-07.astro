const signals = [{"coin": "BTC", "signal": "neutral", "confidence": 43, "rsi1h": 47.01, "rsi4h": 58.92, "change24h": 0.53, "reasons": ["4h MACD bearish cross"]}, {"coin": "ETH", "signal": "neutral", "confidence": 45, "rsi1h": 39.47, "rsi4h": 49.18, "change24h": -0.55, "reasons": []}, {"coin": "SOL", "signal": "neutral", "confidence": 58, "rsi1h": 59.51, "rsi4h": 69.88, "change24h": 3.16, "reasons": []}, {"coin": "ATOM", "signal": "neutral", "confidence": 40, "rsi1h": 43.53, "rsi4h": 48.91, "change24h": 0.9, "reasons": []}, {"coin": "INIT", "signal": "bearish", "confidence": 35, "rsi1h": 63.87, "rsi4h": 76.17, "change24h": 9.71, "reasons": ["4h RSI overbought (76.17)"]}];
const positioning = [{"coin": "BTC", "retailLong": 37.0, "whaleLong": 41.1, "oi": "$8.6B", "oiTrend": "flat", "divergence": null, "retailTrend": "stable"}, {"coin": "ETH", "retailLong": 65.8, "whaleLong": 50.6, "oi": "$5.2B", "oiTrend": "flat", "divergence": "notable divergence (retail: 1.93, whales: 1.02)", "retailTrend": "shifting long \u2014 crowd getting greedy"}, {"coin": "SOL", "retailLong": 62.5, "whaleLong": 66.4, "oi": "$958.1M", "oiTrend": "flat", "divergence": "notable divergence (retail: 1.67, whales: 1.98)", "retailTrend": "stable"}];

const fred = [{"label": "Fed Funds Rate", "value": "3.64%", "change": 0.0}, {"label": "10Y-2Y Spread", "value": "0.49%", "change": -0.01}, {"label": "Breakeven Inflation", "value": "2.42%", "change": -0.05}, {"label": "Unemployment", "value": "4.3%", "change": -0.1}, {"label": "Trade-Weighted USD", "value": "118.3926", "change": -0.28}, {"label": "HY Spread", "value": "2.77%", "change": -0.01}];
const cycle = {"position": "Post-Inversion Watch", "realRate": "1.22%", "realRateDir": "restrictive", "curve": "Post-Inversion Normalization", "hy": "2.77%", "unemployment": "4.3%", "fedFunds": "3.64%", "breakeven": "2.42%"};

const macro = {"totalMC": "$2.8T", "btcDom": 58.6, "ethDom": 10.2, "TNX": 4.356, "GLD": 430.96};

const narrative = "Sentiment neutral at 46. Tape waiting for a catalyst. Real rate at +1.22% (restrictive). Yield curve post-inversion normalization. HY spread at 2.77% \u2014 credit markets pricing complacency. Positioning divergence: ETH: retail 66% long vs whales 51% long. SOL: retail 62% long vs whales 66% long.";

const polymarket = [{"q": "US x Iran permanent peace deal by May 15, 2026?", "yes": 15, "vol": "$2.2M"}, {"q": "Will the U.S. invade Iran before 2027?", "yes": 20, "vol": "$2.0M"}, {"q": "US x Iran permanent peace deal by May 31, 2026?", "yes": 28, "vol": "$1.7M"}, {"q": "US x Iran permanent peace deal by June 30, 2026?", "yes": 47, "vol": "$775,715"}];
const trendingPools = [{"name": "USDUC / SOL", "network": "solana", "vol": "$16.4M", "change": 766.24}, {"name": "MIRROR / WETH", "network": "base", "vol": "$2.1M", "change": -60.0}, {"name": "UTYA / TON", "network": "ton", "vol": "$1.3M", "change": -9.21}, {"name": "REDO / TON", "network": "ton", "vol": "$733,667", "change": -18.83}, {"name": "MTONGA / TON 0.25%", "network": "ton", "vol": "$1.1M", "change": -18.66}];
const tvl = [{"name": "Binance CEX", "tvl": "$159.0B", "change": 0.67}, {"name": "OKX", "tvl": "$25.6B", "change": -0.61}, {"name": "Lido", "tvl": "$21.2B", "change": -1.96}, {"name": "Bitfinex", "tvl": "$19.7B", "change": 0.18}, {"name": "SSV Network", "tvl": "$17.3B", "change": -1.58}, {"name": "Bybit", "tvl": "$16.1B", "change": 0.14}, {"name": "Robinhood", "tvl": "$14.6B", "change": -0.66}, {"name": "Aave V3", "tvl": "$14.5B", "change": -1.66}];


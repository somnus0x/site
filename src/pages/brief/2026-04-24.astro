const trendingPools = [{"name": "ASTEROID / WETH", "network": "eth", "vol": "$9.6M", "change": 258.08}, {"name": "ASTEROID / WETH", "network": "eth", "vol": "$19.9M", "change": -27.88}, {"name": "67 / SOL", "network": "solana", "vol": "$392,643", "change": 34.98}, {"name": "SPIKE / SOL", "network": "solana", "vol": "$1.8M", "change": -3.44}, {"name": "USDF / SOL", "network": "solana", "vol": "$40,893", "change": 660.75}];

const trendingPools = [{"name": "Peepa / SOL", "network": "solana", "vol": "$2.0M", "change": -68.24}, {"name": "TROLL / SOL", "network": "solana", "vol": "$2.4M", "change": -7.86}, {"name": "RAVE / USDT 0.007%", "network": "bsc", "vol": "$16.6M", "change": 33.34}, {"name": "GITLAWB / WETH", "network": "base", "vol": "$441,554", "change": 29.05}, {"name": "Dog / SOL", "network": "solana", "vol": "$1.3M", "change": 423.0}];

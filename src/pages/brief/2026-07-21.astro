const fred = [{"label": "Fed Funds Rate", "value": "3.63%", "change": 0.0}, {"label": "10Y-2Y Spread", "value": "0.39%", "change": 0.02}, {"label": "Breakeven Inflation", "value": "2.25%", "change": 0.01}, {"label": "Unemployment", "value": "4.2%", "change": -0.1}, {"label": "Trade-Weighted USD", "value": "120.5315", "change": 0.2}, {"label": "HY Spread", "value": "2.73%", "change": 0.02}];
const cycle = {"position": "Post-Inversion Watch", "realRate": "1.38%", "realRateDir": "restrictive", "curve": "Post-Inversion Normalization", "hy": "2.73%", "unemployment": "4.2%", "fedFunds": "3.63%", "breakeven": "2.25%"};

const macro = {"totalMC": "$2.3T", "btcDom": 56.6, "ethDom": 9.9, "TNX": 0, "GLD": 0};

const narrative = "Sentiment neutral at 29. Tape waiting for a catalyst. Real rate at +1.38% (restrictive). Yield curve post-inversion normalization. HY spread at 2.73% \u2014 credit markets pricing complacency. Positioning divergence: BTC: retail 55% long vs whales 60% long. ETH: retail 65% long vs whales 58% long. SOL: retail 70% long vs whales 62% long. Capital rotating into Lido, Aave V3, Bybit.";

const polymarket = [{"q": "Will the U.S. invade Iran before 2027?", "yes": 26, "vol": "$768,458"}, {"q": "Will there be no change in Fed interest rates after the July 2026 meeting?", "yes": 92, "vol": "$758,147"}, {"q": "Will the Fed increase interest rates by 25 bps after the July 2026 meeting?", "yes": 6, "vol": "$682,680"}, {"q": "Will Mojtaba Khamenei be head of state in Iran end of 2026?", "yes": 76, "vol": "$178,268"}];
const oddMarkets = [{"q": "Will Trump say \"Crypto / Bitcoin\" before Jul 20, 2026?", "yes": 1, "vol": "$42,213", "exchange": "kalshi"}, {"q": "Will Trump post \"Crypto\" or \"Bitcoin\" on Truth Social this week?", "yes": 2, "vol": "$1,341", "exchange": "polymarket"}, {"q": "Will Elon post \"Crypto\" or \"Bitcoin\" on X this week?", "yes": 12, "vol": "$151.00", "exchange": "polymarket"}];

const narrativeDesk = [{"label": "Crypto Narrative", "accent": "spice", "bullets": ["Market structure shift: Crypto is framed less as speculative beta and more as emerging institutional infrastructure, with DeFi", "TVL shrinking amid security fallout and focus moving from raw deposits to productive, revenue-generating capital.", "Prediction rails mature: Kalshi and Polymarket volumes have ballooned to tens of billions annually, drawing CFTC rulemaking,", "insider-trading prosecutions, and tighter integrity measures that recast prediction markets as supervised derivatives, not"]}, {"label": "AI Discourse", "accent": "water", "bullets": ["Context engineering shift: Research from Anthropic and others frames CLAUDE.md-style files as semantic memory, supporting your", "markdown vault + cron jobs pattern while warning against bloated, over-tagged prompts.", "Memory taxonomy mapping: IBM\u2019s human-memory model (semantic, episodic, procedural, working) aligns cleanly with your cognitive", "infrastructure and flags semantic file poisoning and skill-prompt change control as key governance risks."]}, {"label": "SaaS Gaps", "accent": "safe", "bullets": ["Agency ops tooling: Founder built an internal agency tool that external teams use weekly, signaling demand for focused workflow", "products that beat patched Notion/Airtable stacks.", "Payment-gated delivery: Small businesses struggle with late clients despite using invoicing software, revealing a gap for tools", "that tie deposits, milestones, and delivery locks directly to payment status."]}];

function chgClass(v: number) { return v >= 0 ? 'text-safe' : 'text-crimson'; }

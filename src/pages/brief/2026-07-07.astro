const polymarket = [{"q": "Will there be no change in Fed interest rates after the July 2026 meeting?", "yes": 84, "vol": "$1.1M"}, {"q": "Will the Fed increase interest rates by 25 bps after the July 2026 meeting?", "yes": 15, "vol": "$400,521"}, {"q": "Will Samuel Alito announce his retirement by July 15, 2026?", "yes": 6, "vol": "$302,667"}];
const oddMarkets = [{"q": "Will Elon post \"Crypto\" or \"Bitcoin\" on X this week?", "yes": 0, "vol": "\u2014", "exchange": "polymarket"}, {"q": "Will Trump post \"Crypto\" or \"Bitcoin\" on Truth Social this week?", "yes": 0, "vol": "\u2014", "exchange": "polymarket"}, {"q": "Solana Up or Down - June 7, 2:10AM-2:15AM ET", "yes": 0, "vol": "\u2014", "exchange": "polymarket"}];

const cycle = {"position": "Post-Inversion Watch", "realRate": "1.39%", "realRateDir": "restrictive", "curve": "Post-Inversion Normalization", "hy": "2.71%", "unemployment": "4.2%", "fedFunds": "3.63%", "breakeven": "2.24%"};


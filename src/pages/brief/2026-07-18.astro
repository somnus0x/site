const polymarket = [{"q": "Will there be no change in Fed interest rates after the July 2026 meeting?", "yes": 94, "vol": "$655,566"}, {"q": "Will the U.S. invade Iran before 2027?", "yes": 27, "vol": "$633,048"}, {"q": "Will the Fed increase interest rates by 25 bps after the July 2026 meeting?", "yes": 5, "vol": "$531,068"}, {"q": "Will Ukraine recapture Crimean territory by December 31, 2026?", "yes": 8, "vol": "$361,633"}];

const trendingPools = [{"name": "ASTEROID / WETH", "network": "eth", "vol": "$53.2M", "change": 5.06}, {"name": "AstroFund / WBNB", "network": "bsc", "vol": "$588,724", "change": 800.43}, {"name": "ASTEROID / WETH", "network": "eth", "vol": "$2.7M", "change": -50.73}, {"name": "RAVE / USDT 0.007%", "network": "bsc", "vol": "$133.3M", "change": -79.57}, {"name": "RAVE / USDC 0.3%", "network": "base", "vol": "$5.5M", "change": -79.29}];

const polymarket = [{"q": "US x Iran permanent peace deal by June 15, 2026?", "yes": 13, "vol": "$1.6M"}, {"q": "Will Spencer Pratt win the 2026 Los Angeles mayoral election?", "yes": 8, "vol": "$651,127"}, {"q": "US-Iran nuclear deal by June 30?", "yes": 30, "vol": "$412,763"}, {"q": "Will Tom Steyer win the California Governor Election in 2026?", "yes": 13, "vol": "$384,346"}];
const trendingPools = [{"name": "DOGEUS / SOL", "network": "solana", "vol": "$1.4M", "change": 52.28}, {"name": "SPCX / WETH", "network": "eth", "vol": "$713,434", "change": -52.05}, {"name": "BLKH / VIRTUAL", "network": "base", "vol": "$40,381", "change": -41.84}, {"name": "three / SOL", "network": "solana", "vol": "$3.8M", "change": 60.54}, {"name": "cbBTC / USDC 0.05%", "network": "base", "vol": "$236.0M", "change": -3.72}];
const tvl = [{"name": "Binance CEX", "tvl": "$143.6B", "change": -2.02}, {"name": "OKX", "tvl": "$22.5B", "change": -1.47}, {"name": "Bitfinex", "tvl": "$17.8B", "change": -4.83}, {"name": "Lido", "tvl": "$16.2B", "change": -4.04}, {"name": "Bybit", "tvl": "$14.5B", "change": -1.12}, {"name": "SSV Network", "tvl": "$13.5B", "change": -4.07}, {"name": "Aave V3", "tvl": "$12.3B", "change": -2.76}, {"name": "Robinhood", "tvl": "$11.6B", "change": -3.42}];


const fred = [{"label": "Fed Funds Rate", "value": "3.62%", "change": 0.0}, {"label": "10Y-2Y Spread", "value": "0.41%", "change": 0.0}, {"label": "Breakeven Inflation", "value": "2.38%", "change": -0.01}, {"label": "Unemployment", "value": "4.3%", "change": 0.0}, {"label": "Trade-Weighted USD", "value": "118.8783", "change": -0.15}, {"label": "HY Spread", "value": "2.71%", "change": -0.01}];
const cycle = {"position": "Post-Inversion Watch", "realRate": "1.24%", "realRateDir": "restrictive", "curve": "Post-Inversion Normalization", "hy": "2.71%", "unemployment": "4.3%", "fedFunds": "3.62%", "breakeven": "2.38%"};


const narrativeDesk = [{"label": "Crypto Narrative", "accent": "spice", "bullets": ["Market structure shift: Crypto is framed less as speculative beta and more as emerging institutional infrastructure, with DeFi", "TVL shrinking amid security fallout and focus moving from raw deposits to productive, revenue-generating capital.", "Prediction rails mature: Kalshi and Polymarket volumes have ballooned to tens of billions annually, drawing CFTC rulemaking,", "insider-trading prosecutions, and tighter integrity measures that recast prediction markets as supervised derivatives, not"]}, {"label": "AI Discourse", "accent": "water", "bullets": ["Context engineering shift: Anthropic details moving from ad-hoc prompts to structured context engineering, endorsing persistent", "external memory, compaction, and judicious, well-scoped system prompts.", "Modular memory architectures: A Reddit-built \"SuperContext\" framework challenges monolithic CLAUDE.md files, favoring small", "constitutions, living memory, and project brains activated on demand via databases and session logs."]}, {"label": "SaaS Gaps", "accent": "safe", "bullets": ["Ops research gap: Reddit threads reveal founders struggling to track the few high-signal discussions across Reddit/X/forums;", "current tools surface data but not a daily \"top 5 that matter\" feed.", "Visitor intent clarity: Builders want a way to converse with and interpret website visitors\u2019 behavior in plain language, beyond", "siloed analytics, heatmaps, and chat, suggesting room for a unified intent layer."]}];


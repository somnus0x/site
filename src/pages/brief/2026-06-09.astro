const trendingPools = [{"name": "SPCX / WETH", "network": "eth", "vol": "$951,573", "change": 63.01}, {"name": "WORLDCUP / SOL", "network": "solana", "vol": "$2.4M", "change": 11.38}, {"name": "pippin / SOL", "network": "solana", "vol": "$12.1M", "change": 44.01}, {"name": "GO / SOL", "network": "solana", "vol": "$2.4M", "change": 1490.75}, {"name": "PARQ / USDC", "network": "solana", "vol": "$2.1M", "change": 78.9}];

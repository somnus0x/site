const fred = [{"label": "Fed Funds Rate", "value": "3.63%", "change": 0.0}, {"label": "10Y-2Y Spread", "value": "0.37%", "change": -0.04}, {"label": "Breakeven Inflation", "value": "2.24%", "change": 0.02}, {"label": "Unemployment", "value": "4.2%", "change": -0.1}, {"label": "Trade-Weighted USD", "value": "120.5046", "change": -0.25}, {"label": "HY Spread", "value": "2.71%", "change": 0.0}];
const cycle = {"position": "Post-Inversion Watch", "realRate": "1.39%", "realRateDir": "restrictive", "curve": "Post-Inversion Normalization", "hy": "2.71%", "unemployment": "4.2%", "fedFunds": "3.63%", "breakeven": "2.24%"};


const polymarket = [{"q": "Will the U.S. invade Iran before 2027?", "yes": 30, "vol": "$464,512"}, {"q": "Will Mojtaba Khamenei be head of state in Iran end of 2026?", "yes": 73, "vol": "$244,776"}, {"q": "Will there be no change in Fed interest rates after the July 2026 meeting?", "yes": 94, "vol": "$167,502"}, {"q": "Will WTI Crude Oil (WTI) hit (HIGH) $90 in July?", "yes": 48, "vol": "$136,157"}];
const oddMarkets = [{"q": "Will Trump say \"Crypto / Bitcoin\" before Jul 20, 2026?", "yes": 4, "vol": "$12,946", "exchange": "kalshi"}, {"q": "Will Elon post \"Crypto\" or \"Bitcoin\" on X this week?", "yes": 7, "vol": "$772.00", "exchange": "polymarket"}, {"q": "Will the White House Press Secretary say Crypto / Bitcoin at her next press brie", "yes": 4, "vol": "$864.00", "exchange": "kalshi"}];

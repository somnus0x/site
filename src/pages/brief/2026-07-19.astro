const tvl = [{"name": "Binance CEX", "tvl": "$137.6B", "change": 0.46}, {"name": "OKX", "tvl": "$22.0B", "change": 0.41}, {"name": "Lido", "tvl": "$17.1B", "change": 0.59}, {"name": "Bitfinex", "tvl": "$16.8B", "change": 0.42}, {"name": "Aave V3", "tvl": "$13.7B", "change": 0.65}, {"name": "Bybit", "tvl": "$13.4B", "change": 0.26}, {"name": "Robinhood", "tvl": "$11.6B", "change": 0.96}, {"name": "SSV Network", "tvl": "$9.0B", "change": 0.8}];
const narrativeDesk = [{"label": "Crypto Narrative", "accent": "spice", "bullets": ["Regulatory endgame: US GENIUS and CLARITY Acts plus MiCA\u2019s full activation are formalizing stablecoins and pushing prediction", "markets toward CFTC-style derivatives oversight.", "DeFi consolidation: Post-exploit caution is driving TVL into a smaller set of audited lending and yield primitives, with", "\u201cproductive TVL\u201d framed as real infrastructure for institutional capital."]}, {"label": "AI Discourse", "accent": "water", "bullets": ["Context engineering emerges: Sourcegraph and Anthropic frame prompts as a pipeline, validating persistent memory files,", "selective retrieval, and compacted notes over bloated CLAUDE.md setups.", "Specs as source of truth: Addy Osmani argues for living SPEC.md files with explicit boundaries, self-checks, and modular", "prompts to reduce forgetfulness across agent sessions."]}, {"label": "SaaS Gaps", "accent": "safe", "bullets": ["AR automation gap: Small businesses struggle with late invoices and rely on manual reminders or bloated accounting suites,", "creating room for a focused AR follow-up tool with light integrations.", "QuickBooks exit wedge: Owners resent Intuit lock-in and subscription bloat, often resorting to fragile spreadsheets, signaling", "demand for a migration-focused, lean bookkeeping alternative."]}];

function chgClass(v: number) { return v >= 0 ? 'text-safe' : 'text-crimson'; }
function chgStr(v: number) { return `${v >= 0 ? '▲ +' : '▼ '}${v.toFixed(2)}%`; }
---

<Layout title="brief — Sunday, July 19, 2026" description="12-source automated market intelligence briefing" wide>
  <div class="space-y-8">

    {/* MASTHEAD */}
    <div class="text-center animate-fade-up">
      <p class="font-mono text-xs tracking-[0.2em] text-faint uppercase">{date}</p>
      <h1 class="font-display text-4xl md:text-5xl font-normal mt-2 tracking-tight">market intelligence</h1>
      <p class="font-mono text-xs tracking-[0.15em] text-faint mt-3 uppercase">12 data sources · automated briefing</p>
    </div>

    {/* EDITION BAR */}
    <div class="flex justify-between font-mono text-xs text-faint uppercase tracking-wider border-y border-border py-3 animate-fade-up delay-1">
      <span>morning edition</span>
      <span>updated {updateTime}</span>
      <span>vol. I · no. {volNum}</span>
    </div>

    {/* TICKER */}
    <div class="grid grid-cols-3 md:grid-cols-7 gap-4 py-4 border-y-2 border-border-strong animate-fade-up delay-1">
      {ticker.map((t) => (
        <div class="text-center">
          <div class="font-mono text-xs tracking-wider text-faint uppercase">{t.sym}</div>
          <div class="font-display text-lg mt-0.5">{t.pr}</div>
          {t.chg !== null && t.chg !== undefined ? (
            <span class={`font-mono text-xs ${chgClass(t.chg)}`}>{chgStr(t.chg)}</span>
          ) : t.label ? (
            <span class={`font-mono text-xs ${parseInt(fng.value) <= 30 ? 'text-crimson' : parseInt(fng.value) >= 60 ? 'text-safe' : 'text-dim'}`}>{t.label}</span>
          ) : null}
        </div>
      ))}
    </div>

    {/* HEADLINE */}
    <div class="animate-fade-up delay-2">
      <h2 class="font-display text-3xl md:text-4xl font-normal leading-tight">{headline}</h2>
      <p class="font-mono text-sm text-dim mt-2 pb-5 border-b border-border">{subheadline}</p>
    </div>

    {/* NARRATIVE */}
    <div class="max-w-[640px] animate-fade-up delay-2">
      <p class="text-dim text-base leading-relaxed">{narrative}</p>
    </div>

    {/* NARRATIVE DESK — editorial intelligence (perplexity) */}
    {narrativeDesk.length > 0 && (
      <div class="animate-fade-up delay-2">
        <p class="font-mono text-xs text-spice uppercase tracking-[0.2em] mb-1">narrative desk</p>
        <h3 class="font-display text-xl border-b-2 border-border-strong pb-1 mb-5">What The Week Is Saying</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {narrativeDesk.map((col) => (
            <div class={`border-l-2 border-${col.accent} pl-4`}>
              <h4 class={`font-mono text-xs uppercase tracking-wider mb-3 text-${col.accent}`}>{col.label}</h4>
              <ul class="space-y-2.5">
                {col.bullets.map((b) => (
                  <li class="text-dim text-sm leading-snug flex gap-2">
                    <span class={`text-${col.accent} mt-0.5`}>·</span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    )}

    {/* MAIN CONTENT */}
    <div class="grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-10 animate-fade-up delay-3">

      {/* LEFT COLUMN */}
      <div class="lg:border-r lg:border-border lg:pr-10 space-y-10">

        {/* TECHNICALS */}
        <div>
          <p class="font-mono text-xs text-spice uppercase tracking-[0.2em] mb-1">technical analysis</p>
          <h3 class="font-display text-xl border-b-2 border-border-strong pb-1 mb-4">Signal Dashboard</h3>
          <div class="overflow-x-auto">
            <table class="w-full font-mono text-sm">
              <thead>
                <tr class="text-faint text-xs uppercase tracking-wider border-b border-border">
                  <th class="text-left py-2 font-normal">Asset</th>
                  <th class="text-left py-2 font-normal">Signal</th>
                  <th class="text-left py-2 font-normal">Conv.</th>
                  <th class="text-right py-2 font-normal">RSI 1h</th>
                  <th class="text-right py-2 font-normal">RSI 4h</th>
                  <th class="text-right py-2 font-normal">24h</th>
                </tr>
              </thead>
              <tbody>
                {signals.map((s) => (
                  <tr class="border-b border-border">
                    <td class="py-2.5 text-text font-medium">{s.coin}</td>
                    <td class="py-2.5">
                      <span class={`text-xs uppercase tracking-wide ${s.signal === 'bullish' ? 'text-safe' : s.signal === 'bearish' ? 'text-crimson' : 'text-faint'}`}>{s.signal}</span>
                    </td>
                    <td class="py-2.5">
                      <div class="flex items-center gap-2">
                        <div class="w-16 h-1 bg-surface-2 rounded-full overflow-hidden">
                          <div class={`h-full rounded-full ${s.signal === 'bullish' ? 'bg-safe' : s.signal === 'bearish' ? 'bg-crimson' : 'bg-faint'}`} style={`width:${s.confidence}%`}></div>
                        </div>
                        <span class="text-xs text-dim">{s.confidence}</span>
                      </div>
                    </td>
                    <td class="py-2.5 text-right text-dim tabular-nums">{s.rsi1h ? Math.round(s.rsi1h) : '—'}</td>
                    <td class="py-2.5 text-right text-dim tabular-nums">{s.rsi4h ? Math.round(s.rsi4h) : '—'}</td>
                    <td class={`py-2.5 text-right tabular-nums ${s.change24h !== null ? chgClass(s.change24h) : 'text-dim'}`}>{s.change24h !== null ? chgStr(s.change24h) : '—'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        {/* POSITIONING */}
        <div>
          <p class="font-mono text-xs text-spice uppercase tracking-[0.2em] mb-1">derivatives</p>
          <h3 class="font-display text-xl border-b-2 border-border-strong pb-1 mb-4">Futures Positioning</h3>
          <div class="space-y-6">
            {positioning.map((p) => (
              <div>
                <div class="flex justify-between items-baseline mb-2">
                  <span class="font-display text-lg">{p.coin}</span>
                  <span class="font-mono text-xs text-faint">OI: {p.oi} · {p.oiTrend}</span>
                </div>
                <div class="flex items-center gap-3 mb-1">
                  <span class="font-mono text-xs text-faint uppercase w-12">Retail</span>
                  <div class="flex-1 h-4 bg-surface-2 rounded overflow-hidden flex">
                    <div class="bg-safe/60 flex items-center justify-center text-xs font-mono text-text" style={`width:${p.retailLong}%`}>{p.retailLong.toFixed(0)}%</div>
                    <div class="bg-crimson/40 flex items-center justify-center text-xs font-mono text-text" style={`width:${100 - p.retailLong}%`}>{(100 - p.retailLong).toFixed(0)}%</div>
                  </div>
                </div>
                <div class="flex items-center gap-3">
                  <span class="font-mono text-xs text-faint uppercase w-12">Whales</span>
                  <div class="flex-1 h-4 bg-surface-2 rounded overflow-hidden flex">
                    <div class="bg-water/60 flex items-center justify-center text-xs font-mono text-text" style={`width:${p.whaleLong}%`}>{p.whaleLong.toFixed(0)}%</div>
                    <div class="bg-crimson/30 flex items-center justify-center text-xs font-mono text-text" style={`width:${100 - p.whaleLong}%`}>{(100 - p.whaleLong).toFixed(0)}%</div>
                  </div>
                </div>
                {p.divergence && (
                  <div class="mt-2 border-l-2 border-spice bg-surface-2 px-3 py-2 font-mono text-xs text-spice">
                    ⚠ {p.divergence}
                  </div>
                )}
                {p.retailTrend && p.retailTrend !== "stable" && (
                  <p class="font-mono text-xs text-crimson mt-1">↗ {p.retailTrend}</p>
                )}
              </div>
            ))}
          </div>
        </div>

        {/* MACRO */}
        <div>
          <p class="font-mono text-xs text-spice uppercase tracking-[0.2em] mb-1">federal reserve</p>
          <h3 class="font-display text-xl border-b-2 border-border-strong pb-1 mb-4">Macro Intelligence</h3>
          <div class="border-l-2 border-water bg-surface p-5 rounded-r-lg mb-6">
            <h4 class="font-display text-2xl text-water mb-3">{cycle.position}</h4>
            <div class="space-y-1.5 font-mono text-sm">
              <div class="flex justify-between"><span class="text-faint">Real Rate</span><span class={`${cycle.realRateDir === 'restrictive' ? 'text-crimson' : 'text-safe'} font-medium`}>{cycle.realRate} ({cycle.realRateDir})</span></div>
              <div class="flex justify-between border-t border-border pt-1.5"><span class="text-faint">Yield Curve</span><span class="text-text">{cycle.curve}</span></div>
              <div class="flex justify-between border-t border-border pt-1.5"><span class="text-faint">HY Spread</span><span class="text-text">{cycle.hy}</span></div>
              <div class="flex justify-between border-t border-border pt-1.5"><span class="text-faint">Unemployment</span><span class="text-text">{cycle.unemployment}</span></div>
            </div>
            <p class="font-mono text-xs text-faint mt-3">Dalio framework · Real rate = Fed Funds ({cycle.fedFunds}) − Breakeven ({cycle.breakeven})</p>
          </div>
          <table class="w-full font-mono text-sm">
            <thead>
              <tr class="text-faint text-xs uppercase tracking-wider border-b border-border">
                <th class="text-left py-2 font-normal">Indicator</th>
                <th class="text-right py-2 font-normal">Value</th>
                <th class="text-right py-2 font-normal">Change</th>
              </tr>
            </thead>
            <tbody>
              {fred.map((f) => (
                <tr class="border-b border-border">
                  <td class="py-2 text-dim">{f.label}</td>
                  <td class="py-2 text-right text-text tabular-nums">{f.value}</td>
                  <td class={`py-2 text-right tabular-nums ${chgClass(f.change)}`}>
                    {f.change >= 0 ? '+' : ''}{f.change.toFixed(2)}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      {/* SIDEBAR */}
      <div class="space-y-8">
        <div>
          <h3 class="font-display text-xl border-b-2 border-border-strong pb-1 mb-4">Market Sentiment</h3>
          <div class="text-center py-4">
            <div class={`font-display text-6xl ${parseInt(fng.value) <= 25 ? 'text-crimson' : parseInt(fng.value) >= 60 ? 'text-safe' : 'text-dim'}`}>{fng.value}</div>
            <div class={`font-mono text-sm uppercase tracking-[0.2em] mt-1 ${parseInt(fng.value) <= 25 ? 'text-crimson' : parseInt(fng.value) >= 60 ? 'text-safe' : 'text-dim'}`}>{fng.label}</div>
            <div class="mt-4 h-1.5 rounded-full overflow-hidden" style="background:linear-gradient(90deg, var(--color-crimson), var(--color-spice), var(--color-safe))">
              <div class="relative w-full h-full">
                <div class="absolute top-[-3px] w-1 h-[12px] bg-text rounded-sm" style={`left:${fng.value}%;transform:translateX(-50%)`}></div>
              </div>
            </div>
            <p class="font-mono text-xs text-faint mt-2">0 = extreme fear · 100 = extreme greed</p>
          </div>
        </div>

        <div>
          <h3 class="font-display text-xl border-b-2 border-border-strong pb-1 mb-4">Market Overview</h3>
          <div class="space-y-0 font-mono text-sm">
            {[
              {label:"Total Market Cap", value:macro.totalMC},
              {label:"BTC Dominance", value:`${macro.btcDom.toFixed(1)}%`},
              {label:"ETH Dominance", value:`${macro.ethDom.toFixed(1)}%`},
              {label:"10Y Yield", value:`${macro.TNX.toFixed(2)}%`},
              {label:"Gold", value:`$${macro.GLD.toFixed(0)}`},
            ].map((m) => (
              <div class="flex justify-between py-2 border-b border-border">
                <span class="text-faint">{m.label}</span>
                <span class="text-text tabular-nums">{m.value}</span>
              </div>
            ))}
          </div>
        </div>

        <div>
          <h3 class="font-display text-xl border-b-2 border-border-strong pb-1 mb-4">Key Signals</h3>
          {positioning.filter(p => p.divergence).map((p) => (
            <div class="border-l-2 border-spice bg-surface px-3 py-2 mb-2 font-mono text-xs text-spice">
              ⚠ {p.coin}: {p.divergence}
            </div>
          ))}
          {positioning.filter(p => p.retailTrend && p.retailTrend !== "stable").map((p) => (
            <div class="border-l-2 border-crimson bg-surface px-3 py-2 mb-2 font-mono text-xs text-crimson">
              ↗ {p.coin} retail {p.retailTrend}
            </div>
          ))}
        </div>

        <div>
          <h3 class="font-display text-xl border-b-2 border-border-strong pb-1 mb-4">Prediction Markets</h3>
          <div class="space-y-0">
            {polymarket.map((m) => (
              <div class="py-3 border-b border-border">
                <p class="text-dim text-sm leading-snug">{m.q}</p>
                <p class="font-mono text-xs text-faint mt-1">
                  <span class={m.yes > 50 ? 'text-safe font-medium' : 'text-crimson font-medium'}>{m.yes}% Yes</span>
                  <span class="mx-2">·</span>
                  Vol: {m.vol}
                </p>
              </div>
            ))}
          </div>
          {oddMarkets.length > 0 && (
            <div class="mt-4">
              <h4 class="font-mono text-xs text-faint uppercase tracking-wider mb-2">kalshi · oddpool</h4>
              <div class="space-y-0">
                {oddMarkets.map((m) => (
                  <div class="py-2.5 border-b border-border">
                    <p class="text-dim text-sm leading-snug">{m.q}</p>
                    <p class="font-mono text-xs text-faint mt-1">
                      <span class={m.yes > 50 ? 'text-safe font-medium' : 'text-crimson font-medium'}>{m.yes}% Yes</span>
                      <span class="mx-2">·</span>
                      Vol: {m.vol}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>

    {/* BOTTOM */}
    <div class="animate-fade-up delay-4">
      <p class="font-mono text-xs text-spice uppercase tracking-[0.2em] mb-1">on-chain flow</p>
      <h3 class="font-display text-xl border-b-2 border-border-strong pb-1 mb-6">DEX Activity & Trending Pools</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="border border-border rounded-xl bg-surface p-5">
          <h4 class="font-mono text-xs text-faint uppercase tracking-wider mb-3">trending pools</h4>
          {trendingPools.map((p) => (
            <div class="py-2 border-b border-border last:border-b-0">
              <div class="font-display text-sm">{p.name}</div>
              <div class="font-mono text-xs text-faint">
                {p.network} · {p.vol} <span class={chgClass(p.change)}>{chgStr(p.change)}</span>
              </div>
            </div>
          ))}
        </div>
        <div class="border border-border rounded-xl bg-surface p-5 md:col-span-2">
          <h4 class="font-mono text-xs text-faint uppercase tracking-wider mb-3">defi tvl — top 8</h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6">
            {tvl.map((p) => (
              <div class="flex justify-between py-2 border-b border-border">
                <span class="font-display text-sm">{p.name}</span>
                <span class="font-mono text-xs text-faint">
                  {p.tvl} <span class={chgClass(p.change)}>{p.change >= 0 ? '+' : ''}{p.change}%</span>
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="text-center font-mono text-xs text-faint tracking-wider uppercase border-t border-border pt-6">
      {date} · data from 12 sources · not financial advice
    </div>
  </div>
</Layout>

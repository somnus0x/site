const ticker = [{"sym": "BTC", "pr": "$62,133", "chg": -2.46, "label": null}, {"sym": "ETH", "pr": "$1,770", "chg": -1.9, "label": null}, {"sym": "SOL", "pr": "$74.67", "chg": -2.67, "label": null}, {"sym": "F&G", "pr": "28", "chg": null, "label": "Fear"}];
const signals = [{"coin": "BTC", "signal": "neutral", "confidence": 37, "rsi1h": 40.3, "rsi4h": 34.47, "change24h": -2.44, "reasons": []}, {"coin": "ETH", "signal": "neutral", "confidence": 60, "rsi1h": 46.52, "rsi4h": 45.39, "change24h": -1.86, "reasons": ["1h MACD bullish cross"]}, {"coin": "SOL", "signal": "neutral", "confidence": 37, "rsi1h": 40.0, "rsi4h": 32.44, "change24h": -2.68, "reasons": []}, {"coin": "ATOM", "signal": "neutral", "confidence": 42, "rsi1h": 38.36, "rsi4h": 37.33, "change24h": -2.23, "reasons": []}, {"coin": "INIT", "signal": "neutral", "confidence": 37, "rsi1h": 33.45, "rsi4h": 30.78, "change24h": -3.44, "reasons": []}];

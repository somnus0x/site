---
import Layout from '../../layouts/Layout.astro';

// Auto-generated index — 2026-04-18T06:55:01.286346+07:00
const editions = ["2026-04-18", "2026-04-17", "2026-04-16", "2026-04-15", "2026-04-14", "2026-04-13", "2026-04-12", "2026-04-11", "2026-04-10"];
---

<Layout title="brief — market intelligence archive" wide>
  <div class="max-w-[600px] mx-auto animate-fade-up">
    <h1 class="font-display text-4xl md:text-5xl font-normal mb-3" style="letter-spacing: -0.03em;">market brief</h1>
    <p class="text-dim text-lg mb-12">daily editions · 12 data sources · automated</p>

    <div class="space-y-0">
      {editions.map((d) => (
        <a href={`/brief/${d}`} class="flex items-baseline justify-between py-4 border-b border-border hover:text-spice transition-colors group">
          <span class="font-display text-xl group-hover:text-spice">{d}</span>
          <span class="font-mono text-xs text-faint group-hover:text-spice">→</span>
        </a>
      ))}
    </div>
  </div>
</Layout>

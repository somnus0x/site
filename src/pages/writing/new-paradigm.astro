---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="new paradigm" description="designer codes. developer codes. biz guy codes. the tool just works for all three now.">
  <div class="max-w-2xl">
    <div class="font-mono text-xs text-faint mb-4 animate-fade-up">
      <a href="/writing" class="text-spice hover:underline">writing</a> <span class="text-faint">/</span> new paradigm
    </div>

    <article class="space-y-6">
      <h1 class="font-display text-4xl font-normal animate-fade-up">new paradigm</h1>

      <div class="text-lg leading-loose space-y-6 animate-fade-up delay-1">
        <p><span class="text-water">designer</span> codes. <span class="text-water">developer</span> codes. <span class="text-water">biz guy</span> codes. not because they learned each other's skills. the tool just works for all three now.</p>

        <p class="text-spice">suddenly, then all at once.</p>
      </div>
    </article>

    <div class="mt-12 pt-6 border-t border-border animate-fade-up delay-2">
      <a href="/writing" class="text-spice hover:underline">← back to writing</a>
    </div>
  </div>
</Layout>

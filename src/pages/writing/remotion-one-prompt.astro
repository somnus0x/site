---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="one prompt, one video" description="heard about remotion. never opened the docs. wrote one paragraph, got a launch video back in 60 seconds.">
  <div class="space-y-6">
    <div class="font-mono text-xs text-faint mb-4">
      <a href="/writing" class="text-accent hover:underline">writing</a> <span class="text-faint">/</span> remotion-one-prompt
    </div>

    <h1 class="font-display text-3xl font-normal animate-fade-up">one prompt, one video</h1>

    <div class="essay mt-10 animate-fade-up delay-1">
      <p>heard about remotion</p>

      <p class="mt-6 text-dim">never opened the docs</p>

      <p class="mt-6">wrote one paragraph to claude code</p>
      <p class="text-spice">got a launch video back in 60 seconds</p>

      <hr class="my-12 border-border" />

      <p>launch videos used to block a full day</p>

      <p class="mt-6 text-dim">storyboard. recordings. timeline. export.</p>
      <p class="text-dim">back and forth. "move this 2 frames left"</p>

      <p class="mt-6 text-crimson">all of that just disappeared</p>

      <hr class="my-12 border-border" />

      <p>you don't learn the tool anymore</p>

      <p class="mt-6">you describe what you want</p>
      <p>to something that knows the tool</p>

      <p class="mt-6 text-gold">taste over technique</p>
    </div>

    <!-- The video -->
    <div class="mt-16 flex justify-center animate-fade-up delay-2">
      <video
        src="/videos/remotion-meta.mp4"
        controls
        playsinline
        class="rounded-xl border border-border max-h-[600px]"
        poster=""
      />
    </div>
    <p class="text-center text-faint text-xs font-mono mt-2">the video. one prompt. one render.</p>

    <div class="mt-16 pt-6 border-t border-border">
      <a href="/writing" class="text-accent hover:underline">← back to writing</a>
    </div>
  </div>
</Layout>

<style>
  .essay p {
    line-height: 1.8;
    margin-bottom: 0.25rem;
  }
</style>

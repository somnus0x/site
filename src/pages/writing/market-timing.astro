---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="market timing" description="co-founded knowhere. terra's first nft marketplace. $30m volume. we were tracking to #1. window closed.">
  <div class="max-w-2xl">
    <div class="font-mono text-xs text-faint mb-4 animate-fade-up">
      <a href="/writing" class="text-accent hover:underline">writing</a> <span class="text-faint">/</span> market timing
    </div>

    <article class="space-y-6">
      <h1 class="font-display text-4xl font-normal animate-fade-up">market timing</h1>

      <div class="text-lg leading-loose space-y-6 animate-fade-up delay-1">
        <p>co-founded knowhere. terra's first nft marketplace. <span class="text-spice">$30m volume.</span> we were tracking to #1. <span class="text-crimson">window closed.</span> market timing beats execution every time.</p>
      </div>
    </article>

    <div class="mt-12 pt-6 border-t border-border animate-fade-up delay-2">
      <a href="/writing" class="text-accent hover:underline">← back to writing</a>
    </div>
  </div>
</Layout>

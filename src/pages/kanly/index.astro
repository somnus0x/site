---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const protocols = (await getCollection('kanly')).sort((a, b) => a.data.order - b.data.order);

const protocolCommands: Record<string, string[]> = {
  handoff: ['write', 'check', 'clear'],
  spec: ['bind', 'note', 'check', 'diff'],
  scope: ['add', 'check', 'list'],
  learn: ['add', 'check', 'list'],
  guard: ['classify', 'check', 'tripwire', 'trace', 'verify'],
  dissent: ['review', 'override', 'log'],
  replace: ['confirm', 'trace', 'execute', 'verify'],
  'design-gate': ['write', 'check', 'review'],
  breakdown: ['write', 'view', 'validate'],
  review: ['write', 'check', 'done'],
  'test-gate': ['check', 'run', 'gate'],
  verify: ['run', 'status'],
};
---

<Layout title="kanly" description="Formal vendetta protocols for honest intellectual conflict" wide>
  <div class="space-y-10">
    <div class="animate-fade-up">
      <p class="font-mono text-xs uppercase tracking-widest text-accent mb-3">Protocols</p>
      <h1 style="font-size: 2.5rem; letter-spacing: -0.025em; margin-bottom: 16px;">kanly</h1>
    </div>

    <div class="text-lg text-text leading-loose space-y-4 ps-prose animate-fade-up delay-1">
      <p>formal vendetta protocols for honest intellectual conflict.</p>
      <p>inspired by dune's kanly — a structured framework for resolving disputes without destroying the relationship. rules that make disagreement productive instead of destructive.</p>
    </div>

    <div class="mt-4 animate-fade-up delay-2">
      <p class="text-dim text-lg leading-relaxed">invoke a protocol when you need friction that prevents mistakes, not friction that slows you down. these aren't commands — they're safety checks.</p>
    </div>

    <div class="mt-8 ps-card animate-fade-up delay-2">
      <p class="font-mono text-xs uppercase tracking-widest text-faint mb-3">Install</p>
      <code class="block font-mono text-sm text-accent">git clone https://github.com/somnus0x/kanly.git ~/.claude/skills/kanly</code>
    </div>

    <div class="mt-12 animate-fade-up delay-3">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {protocols.map((protocol) => {
          const commands = protocolCommands[protocol.data.slug] || [];
          return (
            <a
              href={`/kanly/${protocol.data.slug}`}
              class="ps-card ps-card-clickable block no-underline"
            >
              <h3 class="text-accent" style="font-size: 1.25rem; margin-bottom: 8px;">{protocol.data.title}</h3>
              <p class="text-dim" style="margin-bottom: 12px;">{protocol.data.description}</p>
              {commands.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {commands.map((cmd) => (
                    <span class="ps-tag">{cmd}</span>
                  ))}
                </div>
              )}
            </a>
          );
        })}
      </div>
    </div>
  </div>
</Layout>

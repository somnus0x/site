---
import Layout from '../layouts/Layout.astro';
---

<Layout title="writing" description="Essays and threads">
  <div class="space-y-8">
    <h1 class="font-display text-4xl font-normal animate-fade-up">writing</h1>

    <div class="space-y-6 mt-10 animate-fade-up delay-1">
      <a href="/writing/ai-coding" class="block bg-surface border border-border rounded-xl p-7 hover:border-border-hover transition-colors">
        <h2 class="font-display text-xl mb-2">ai in coding</h2>
        <p class="text-dim">not chasing speed — trying to see where it actually changes outcomes. a 10-post thread.</p>
      </a>
    </div>
  </div>
</Layout>
